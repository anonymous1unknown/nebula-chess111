# ─── Nebula Chess — Environment Configuration ───────────────────────────────
# Copy this file to .env and fill in your values before running.
# NEVER commit the actual .env file to version control.

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-please-use-openssl-rand-hex-32-for-production

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=nebula
POSTGRES_PASSWORD=nebula_strong_password_here
POSTGRES_DB=nebula_chess

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis URL (used by backend)
# REDIS_URL=redis://localhost:6379/0

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=production
# development | production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API
# CORS_ORIGINS=["https://yourdomain.com"]

# ── Stockfish ─────────────────────────────────────────────────────────────────
STOCKFISH_PATH=/usr/games/stockfish
STOCKFISH_DEPTH=15
STOCKFISH_THREADS=2

# ── Tokens ────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change-me-grafana-admin-password

# ── Anti-cheat ────────────────────────────────────────────────────────────────
ANTICHEAT_ENGINE_CORRELATION_THRESHOLD=0.85
ANTICHEAT_ACCURACY_THRESHOLD=0.92
ANTICHEAT_MIN_MOVES_TO_EVALUATE=10

# ── ELO ───────────────────────────────────────────────────────────────────────
ELO_K_FACTOR=32
DEFAULT_ELO=1200

# ── Rate Limits ───────────────────────────────────────────────────────────────
AUTH_RATE_LIMIT=10/minute
API_RATE_LIMIT=100/minute
