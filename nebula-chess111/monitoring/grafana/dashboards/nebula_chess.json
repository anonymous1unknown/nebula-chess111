{
  "title": "Nebula Chess — Live Metrics",
  "uid": "nebula-chess-main",
  "version": 1,
  "schemaVersion": 36,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active WebSocket Connections",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(increase(http_requests_total{handler=\"/ws/game/{game_id}\"}[5m]))",
        "legendFormat": "Active WS"
      }],
      "options": { "colorMode": "background" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "API Request Rate",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_requests_total[1m])) * 60",
        "legendFormat": "req/min"
      }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "API Latency (p99)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, handler))",
        "legendFormat": "p99 {{ handler }}"
      }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Error Rate",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (handler)",
        "legendFormat": "5xx {{ handler }}"
      }]
    }
  ]
}
